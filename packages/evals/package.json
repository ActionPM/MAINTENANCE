{
  "name": "@wo-agent/evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "eval:run": "tsx src/cli/run-eval.ts",
    "eval:update-baseline": "tsx src/cli/update-baseline.ts"
  },
  "dependencies": {
    "@wo-agent/schemas": "workspace:*",
    "@wo-agent/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
