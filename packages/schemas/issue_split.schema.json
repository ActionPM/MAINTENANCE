{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "issue_split.schema.json",
  "definitions": {
    "IssueSplitterInput": {
      "type": "object",
      "properties": {
        "raw_text": { "type": "string", "minLength": 1, "maxLength": 8000 },
        "conversation_id": { "type": "string" },
        "taxonomy_version": { "type": "string" },
        "model_id": { "type": "string" },
        "prompt_version": { "type": "string" },
        "cue_version": { "type": "string" }
      },
      "required": ["raw_text", "conversation_id", "taxonomy_version", "model_id", "prompt_version", "cue_version"],
      "additionalProperties": false
    },
    "SplitIssue": {
      "type": "object",
      "properties": {
        "issue_id": { "type": "string" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "raw_excerpt": { "type": "string", "minLength": 1 }
      },
      "required": ["issue_id", "summary", "raw_excerpt"],
      "additionalProperties": false
    },
    "IssueSplitterOutput": {
      "type": "object",
      "properties": {
        "issues": {
          "type": "array",
          "items": { "$ref": "#/definitions/SplitIssue" },
          "minItems": 1,
          "maxItems": 10
        },
        "issue_count": { "type": "integer", "minimum": 1, "maximum": 10 }
      },
      "required": ["issues", "issue_count"],
      "additionalProperties": false
    }
  }
}
