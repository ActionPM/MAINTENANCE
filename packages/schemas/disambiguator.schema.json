{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "disambiguator.schema.json",
  "definitions": {
    "DisambiguatorOutput": {
      "type": "object",
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["clarification", "new_issue"]
        },
        "reasoning": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "required": ["classification", "reasoning"],
      "additionalProperties": false
    }
  }
}
