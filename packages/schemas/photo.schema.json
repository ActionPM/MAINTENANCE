{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "photo.schema.json",
  "definitions": {
    "Photo": {
      "type": "object",
      "properties": {
        "photo_id": { "type": "string", "format": "uuid" },
        "conversation_id": { "type": "string", "format": "uuid" },
        "work_order_id": { "type": ["string", "null"], "format": "uuid" },
        "filename": { "type": "string", "minLength": 1 },
        "content_type": {
          "type": "string",
          "enum": ["image/jpeg", "image/png", "image/heic", "image/webp"]
        },
        "size_bytes": { "type": "integer", "minimum": 1, "maximum": 10485760 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "storage_key": { "type": "string", "minLength": 1 },
        "scanned_status": {
          "type": "string",
          "enum": ["pending", "clean", "infected", "error"]
        },
        "uploaded_by": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": [
        "photo_id",
        "conversation_id",
        "filename",
        "content_type",
        "size_bytes",
        "sha256",
        "storage_key",
        "scanned_status",
        "uploaded_by",
        "created_at"
      ],
      "additionalProperties": false
    }
  }
}
