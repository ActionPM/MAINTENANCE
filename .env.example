# Example placeholders only. Do not commit real credentials.
# A live DATABASE_URL embeds database credentials; rotate the password only if
# an actual non-placeholder value was exposed outside your secret manager.
#
# Neon PostgreSQL connection string (pooled endpoint for serverless)
# Get from: https://console.neon.tech → your project → Connection Details → Pooled
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# JWT secrets (32+ chars each)
JWT_ACCESS_SECRET=change-me-to-a-real-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-real-secret-at-least-32-chars

# Anthropic API key for LLM tools (IssueSplitter, IssueClassifier, FollowUpGenerator)
# Get from: https://console.anthropic.com/settings/keys
# If not set, stubs with hardcoded responses are used (safe for local dev)
ANTHROPIC_API_KEY=

# Optional: override the default LLM model (default: claude-sonnet-4-20250514)
# LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001

# --- Cron & Observability ---
# Shared secret for Vercel cron job authentication (Authorization: Bearer <secret>)
CRON_SECRET=

# Enable observability alert evaluation cron (set to "true" to activate)
# OBSERVABILITY_ALERTS_ENABLED=true

# Comma-separated phone numbers for ops alert SMS delivery
# OPS_ALERT_PHONE_NUMBERS=+15551234567,+15559876543

# --- Emergency Escalation ---
# Enable emergency routing and escalation cron (set to "true" to activate)
# EMERGENCY_ROUTING_ENABLED=true

# Internal fallback number when escalation chain is exhausted
# EMERGENCY_INTERNAL_ALERT_NUMBER=+15550000000

# --- Twilio (required for SMS/voice alerts and emergency escalation) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15551112222
# Base URL for Twilio voice/SMS webhooks (e.g. https://your-app.vercel.app)
# TWILIO_WEBHOOK_BASE_URL=https://your-staging-domain.vercel.app
